<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SystemLosowania.Views.ManageStudentsPage"
             Title="Zarzadzanie Uczniami"
             StyleClass="managePage">

    <ScrollView>
        <VerticalStackLayout Spacing="15" Padding="20" StyleClass="formContainer">
            <Label x:Name="ClassTitleLabel" StyleClass="pageTitle" />

            <Label Text="Dodaj Nowego Ucznia" StyleClass="sectionLabel" />

            <Entry x:Name="FirstNameEntry" Placeholder="Imie" StyleClass="inputField" />
            <Entry x:Name="LastNameEntry" Placeholder="Nazwisko" StyleClass="inputField" />

            <Button x:Name="AddButton"
                    Text="Dodaj Ucznia"
                    Clicked="OnAddStudentClicked"
                    StyleClass="primaryButton" />

            <BoxView HeightRequest="2" Color="#CCCCCC" Margin="0,20" />

            <Label Text="Lista Uczniow" StyleClass="sectionLabel" />

            <CollectionView x:Name="StudentsCollection" StyleClass="studentsList">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame StyleClass="studentItemFrame" Margin="0,5">
                            <Grid ColumnDefinitions="*,Auto" Padding="8" ColumnSpacing="8">
                                <Label Text="{Binding FullName}"
                                       Grid.Column="0"
                                       StyleClass="studentNameLabel"
                                       VerticalOptions="Center" />

                                <Button Grid.Column="1"
                                        Text="Usun"
                                        Clicked="OnDeleteStudentClicked"
                                        BackgroundColor="Red"
                                        TextColor="White"
                                        Padding="10,4"
                                        CornerRadius="8" />
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label Text="Kliknij przycisk Usun przy uczniu"
                   StyleClass="hintLabel"
                   Margin="0,10,0,0" />

            <Button x:Name="SaveButton"
                    Text="Zapisz Zmiany"
                    Clicked="OnSaveClicked"
                    StyleClass="saveButton"
                    Margin="0,20,0,0" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
