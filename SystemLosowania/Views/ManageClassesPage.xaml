<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SystemLosowania.Views.ManageClassesPage"
             Title="Zarzadzanie Klasami"
             StyleClass="managePage">
	<ScrollView>
		<VerticalStackLayout Spacing="15" Padding="20" StyleClass="formContainer">
			<Label Text="Utworz Nowa Klase" StyleClass="pageTitle" />
			<Entry x:Name="ClassNameEntry"
                   Placeholder="Wpisz nazwe klasy (np. 3A)"
                   StyleClass="inputField" />
			<Button x:Name="CreateButton"
                    Text="Utworz Klase"
                    Clicked="OnCreateClassClicked"
                    StyleClass="primaryButton" />
			<BoxView HeightRequest="2" Color="#CCCCCC" Margin="0,20" />
			<Label Text="Istniejace Klasy" StyleClass="sectionLabel" />
			<CollectionView x:Name="ExistingClassesCollection" StyleClass="existingList">
				<CollectionView.ItemTemplate>
					<DataTemplate>
						<Frame StyleClass="listItemFrame" Margin="0,5">
							<Grid ColumnDefinitions="*,Auto" Padding="6">
								<Label Text="{Binding}"
                                       StyleClass="listItemLabel"
                                       VerticalOptions="Center" />
								<Button Grid.Column="1"
                                        Text="Usun"
                                        Clicked="OnDeleteClassClicked"
                                        BackgroundColor="Red"
                                        TextColor="White"
                                        Padding="10,4"
                                        CornerRadius="8" />
							</Grid>
						</Frame>
					</DataTemplate>
				</CollectionView.ItemTemplate>
			</CollectionView>
			<Label Text="Kliknij przycisk Usun przy klasie"
                   StyleClass="hintLabel"
                   Margin="0,10,0,0" />
		</VerticalStackLayout>
	</ScrollView>
</ContentPage>
