<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       x:Class="SystemLosowania.Views.SelectClassForEditPage"
   Title="Wybierz Klase"
 StyleClass="selectPage">

    <ScrollView>
        <VerticalStackLayout Spacing="15" Padding="20" StyleClass="formContainer">

            <Label Text="Wybierz Klase do Edycji Uczniow" StyleClass="pageTitle" />

            <CollectionView x:Name="ClassListCollection" StyleClass="selectList">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame StyleClass="selectItemFrame" Margin="0,5">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnClassSelected" />
                            </Frame.GestureRecognizers>
                            <Label Text="{Binding}" StyleClass="selectItemLabel" />
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label x:Name="NoClassesLabel"
                Text="Brak klas. Najpierw utworz klase!"
                StyleClass="hintLabel"
                IsVisible="False"
                Margin="0,20,0,0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
