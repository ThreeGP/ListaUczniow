## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
bld/
[Bb]in/
[Oo]bj/

# Visual Studio cache/options
.vs/

# MAUI specific
**/AppPackages/
**/BundleArtifacts/

# Files generated by .NET MAUI
**/Generated Files/
**/*.g.cs
**/*.g.i.cs

# NuGet Packages
*.nupkg
**/packages/*

# macOS
.DS_Store

# Android
*.apk
*.aab

# iOS
*.ipa

# Windows
*.appx
*.msix
